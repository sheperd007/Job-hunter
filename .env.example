# ===== Postgres =====
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change-me
POSTGRES_DB=n8n
DATABASE_URL=postgresql://n8n:change-me@postgres:5432/n8n

# ===== OpenAI (2 keys, $8 cap each enforced in code by the worker) =====
OPENAI_KEY_A=sk-...   # triage + visa pre-filter (cheap model)
OPENAI_KEY_B=sk-...   # match scoring + reply drafting (stronger model)
OPENAI_BASE_URL=https://api.openai.com/v1   # swap for OpenRouter/Azure/Ollama
MODEL_TRIAGE=gpt-4.1-mini
MODEL_MATCH=gpt-4.1
MODEL_FALLBACK=gpt-4o-mini
MONTHLY_CAP_USD=10.0
CAP_SAFETY_MARGIN_USD=9.5
DAILY_SOFT_CAP_USD=0.33

# ===== Safety =====
DRY_RUN=true          # set false to allow real sends/writes

# ===== n8n / networking =====
TZ=Asia/Tehran
N8N_HOST=localhost
WEBHOOK_URL=http://localhost:5678/
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me

# ===== Notion (worker performs all Notion writes) =====
NOTION_TOKEN=ntn_...     # current tokens start with ntn_ (older ones with secret_); both work
NOTION_APPLICATIONS_DB=70b08f56f7fc4825b9e45993a409cb11   # Applications database id
NOTION_VERSION=2022-06-28

# ===== Telegram =====
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# ===== Digest / Google =====
OWNER_EMAIL=hamidjahani999@gmail.com   # where the daily digest email is sent
WORKER_URL=http://worker:8000          # n8n -> worker (compose internal hostname)
GOOGLE_CALENDAR_ID=primary             # which Google Calendar W5 adds approved events to

# ===== Job source API keys (Phase 2) =====
JOOBLE_KEY=
# Google Jobs via Scrapingdog (aggregates Indeed/Glassdoor/LinkedIn/company sites).
# 1 credit/request; discovery makes google_query_cap x 5 countries per run (default
# 3 x 5 = 15 credits/run). Empty = Google Jobs source skipped. Key:
# https://www.scrapingdog.com/ dashboard.
SCRAPINGDOG_KEY=

# ===== Discovery tuning =====
# Max jobs sent to the (paid) LLM matcher per /jobs/run. Soft visa gate lets
# ~189 in-region jobs/day reach scoring; this caps cost under the $10/mo key cap.
# Unscored jobs are retried on later runs. 60 (~$9.4/mo on gpt-4.1).
MAX_MATCH_PER_RUN=60
# Optional CSV of licensed visa sponsors (UK Home Office "Register of licensed
# sponsors: workers"). Employers on it are flagged "On sponsor register" (strongest
# signal) and sorted to the top. Empty = check skipped. The UK CSV filename rotates
# daily, so set this to "govuk:workers" to auto-resolve the current CSV via the
# gov.uk content API, or paste a direct CSV link. Best-effort: never breaks discovery.
SPONSOR_REGISTER_URL=govuk:workers

# --- Visa/relocation ranking ---
# Effective Notion "Match score" = clamp(raw + weight*(visa_confidence-0.5)), so
# relocation/visa-bearing jobs rise to the top. 0 = ranking off (pure fit).
VISA_RANK_WEIGHT=20
# Min LLM visa-intent confidence (0..1) to upgrade a keyword-"Unclear" job.
LLM_VISA_MIN_CONF=0.6
# Google Jobs query bias: suffixes appended to the top base term (JSON list).
# Empty list [] = no bias. More on-target jobs; costs a little more Scrapingdog.
VISA_QUERY_SUFFIXES=["visa sponsorship","relocation"]
# Hard cap on distinct Google query strings per country (credit guard).
GOOGLE_QUERY_CAP=3

# ===== Google OAuth (configured in n8n UI; domain only needed for proxy profile) =====
# DOMAIN=jobs.example.com
# N8N_BASIC_AUTH_PASSWORD_HASH=   # caddy basic_auth hash (run: caddy hash-password)

# ===== Hardened mode only (docs/SECURITY.md) =====
# In hardened mode, secrets live in ./secrets/* files, NOT here. Keep this file
# secret-free and set only non-sensitive config.
DATA_DIR=./data                   # set to your LUKS mount (e.g. /mnt/agentdata) for encryption at rest
