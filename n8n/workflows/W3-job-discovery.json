{
  "name": "W3 - Job Discovery",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            { "field": "cronExpression", "expression": "0 6 * * *" }
          ]
        }
      },
      "id": "schedule-w3",
      "name": "Daily 06:00",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.3,
      "position": [240, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.WORKER_URL }}/jobs/run",
        "options": { "timeout": 600000 }
      },
      "id": "http-jobs-run",
      "name": "worker /jobs/run",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [480, 300],
      "retryOnFail": true,
      "maxTries": 3,
      "onError": "continueRegularOutput"
    }
  ],
  "connections": {
    "Daily 06:00": {
      "main": [
        [ { "node": "worker /jobs/run", "type": "main", "index": 0 } ]
      ]
    }
  },
  "settings": { "executionOrder": "v1" }
}
